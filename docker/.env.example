# ── Admin credentials (auto-created on first start) ──
CHATAPI_ADMIN_USERNAME=admin
CHATAPI_ADMIN_PASSWORD=change-me

# ── Flask settings ──
CHATAPI_HOST=0.0.0.0
CHATAPI_PORT=5000

# ── CORS: allow requests from nginx origin ──
CHATAPI_CORS_ORIGINS=http://localhost

# ── Session secret (optional; auto-generated if blank) ──
# CHATAPI_SESSION_SECRET=your-session-secret

# ── Database ──
CHATAPI_DB_PATH=/app/data/chatapi.sqlite3
CHATAPI_DATA_DIR=/app/data

# ── Email (optional) ──
# CHATAPI_EMAIL_FROM=noreply@example.com
# CHATAPI_SMTP_HOST=smtp.example.com
# CHATAPI_RESEND_API_KEY=re_xxxxxxxxx
